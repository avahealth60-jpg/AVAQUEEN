# ────────────────────────────────────────────────────────────────
# AVA Health — contoh environment variables
# Salin ke .env.local (per app) atau set di dashboard Vercel/Supabase.
# JANGAN commit nilai asli. File ini hanya template.
# ────────────────────────────────────────────────────────────────

# ── Supabase (publik — aman dikirim ke browser) ──────────────────
# Dari: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# ── Supabase (RAHASIA — HANYA untuk Edge Functions / server) ─────
# JANGAN PERNAH masukkan ke app Next.js / browser.
# Hanya dipakai di supabase/functions/* (server-side).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ── LLM provider (untuk ai-analyze edge function) ────────────────
# Keputusan provider masih TERBUKA (lihat README → Keputusan terbuka).
# Field di bawah placeholder; isi setelah provider dipilih.
LLM_API_KEY=
LLM_MODEL=

# ── URL antar-app (untuk "Buka sebagai" di konsol Super Admin) ───
# Monorepo = 3 deploy Vercel terpisah. Default kode sudah menunjuk produksi;
# override HANYA bila URL berbeda (mis. dev lokal). Set di project ADMIN.
# Produksi saat ini:
#   Customer : https://avaqueen-customer.vercel.app
#   Partner  : https://avaqueen-partner.vercel.app
#   Admin    : https://avaqueen-admin.vercel.app
NEXT_PUBLIC_CUSTOMER_URL=https://avaqueen-customer.vercel.app
NEXT_PUBLIC_PARTNER_URL=https://avaqueen-partner.vercel.app

# ── CI/CD (GitHub Actions secrets, untuk deploy job) ─────────────
# Set di: GitHub repo → Settings → Secrets and variables → Actions
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_REF=
